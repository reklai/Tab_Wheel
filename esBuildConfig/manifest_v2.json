{
  "manifest_version": 2,
  "name": "TabWheel - Mouse Wheel Tab Switcher",
  "version": "1.0.1",
  "description": "Mouse wheel tab switcher with hold-swipe tab actions, Wheel List mode, and local-only settings.",
  "browser_specific_settings": {
    "gecko": {
      "id": "@tabwheel.reklai",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "tabs",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "optionsPage/optionsPage.html",
    "open_in_tab": true
  },
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_popup": "toolbarPopup/toolbarPopup.html",
    "default_title": "TabWheel - Mouse Wheel Tab Switcher"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  }
}
